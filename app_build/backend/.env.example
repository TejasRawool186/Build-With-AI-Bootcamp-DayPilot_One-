# DayPilot One — Environment Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required for AI reasoning)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (required for real weather data)
# Get yours at: https://openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Email Configuration (optional — for sending daily briefings)
# For Gmail: Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Flask Configuration
FLASK_DEBUG=true
PORT=5000
